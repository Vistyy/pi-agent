# Ignore everything by default
*

# Track this file
!.gitignore

# Core config
!AGENTS.md
!SYSTEM.md
!APPEND_SYSTEM.md
!settings.json
!models.json
!keybindings.json
!session-recall.json
!pi-auto-permissions/
!pi-auto-permissions/config.json

# Track resource directories
!agents/
!agents/**
!extensions/
!extensions/**
!prompts/
!prompts/**
!skills/
!skills/**
!user-skills/
!user-skills/**
!themes/
!themes/**
!docs/
!docs/**
!eval/
!eval/**
eval/fixtures/**/source.jsonl
!eval/fixtures/**/source.synthetic.jsonl
eval/scratch-historical/
eval/runs/

# But ignore dependency/build artifacts inside tracked dirs
node_modules/
**/node_modules/
dist/
**/dist/
*.log

# Never track secrets/runtime
auth.json
sessions/
npm/
git/
pi-debug.log
