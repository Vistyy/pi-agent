{
  "lastChangelogVersion": "0.80.10",
  "skills": [
    "user-skills"
  ],
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "doubleEscapeAction": "tree",
  "theme": "rose-pine-moon",
  "packages": [
    "../../projects/pi-extensions/pi-lavish",
    "../../projects/pi-extensions/pi-subagent"
  ],
  "extensions": [
    "-extensions/pi-swop/index.ts"
  ],
  "terminal": {
    "clearOnShrink": false
  },
  "enabledModels": [
    "openai-codex/gpt-5.6-sol",
    "openai-codex/gpt-5.6-terra",
    "openai-codex/gpt-5.6-luna"
  ],
  "pi-subagent": {
    "fork": {
      "tools": "read,bash,grep,find,ls,web_search,web_fetch,web_content_get",
      "extensions": [
        "./extensions/openai-fast.ts",
        "./extensions/web-search",
        "./extensions/package-manager-policy",
        "~/projects/pi-extensions/pi-subagent/sandbox.ts"
      ],
      "offline": true,
      "activation": {
        "command": "direnv",
        "args": [
          "exec",
          "{cwd}"
        ]
      },
      "sandbox": {
        "bashNetwork": true,
        "homeAccess": "overlay",
        "workspaceAccess": "overlay",
        "tmpDir": "/tmp"
      },
      "defaultEffort": "fast",
      "effortProfiles": {
        "fast": {
          "provider": "openai-codex",
          "id": "gpt-5.6-luna",
          "thinking": "low"
        },
        "balanced": {
          "provider": "openai-codex",
          "id": "gpt-5.6-luna",
          "thinking": "medium"
        },
        "deep": {
          "provider": "openai-codex",
          "id": "gpt-5.6-luna",
          "thinking": "high"
        }
      }
    },
    "subagent": {
      "extensions": [
        "./extensions/openai-fast.ts",
        "./extensions/web-search",
        "./extensions/package-manager-policy"
      ],
      "offline": true
    }
  },
  "showCacheMissNotices": true
}